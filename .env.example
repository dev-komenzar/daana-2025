# microCMS (現行 Vercel 本番。Stage 6 で撤廃予定)
MICROCMS_API_KEY=your_microcms_api_key_here

# PocketBase (Stage 1〜 ローカル開発で使用)
PB_URL=http://localhost:8090
PB_ADMIN_EMAIL=admin@example.com
PB_ADMIN_PASSWORD=change-me-in-your-local-env

# CMS ソース切替フラグ
# 未設定時は "microcms" として動作 (既存挙動)
# CMS_SOURCE=microcms  # or "pocketbase"
