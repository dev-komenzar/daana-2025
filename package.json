{
	"name": "daana-2025",
	"private": true,
	"version": "3.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "husky",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "eslint --fix .",
		"lint:ci": "eslint .",
		"lint:style": "stylelint --fix --ignore-path .gitignore '**/*.{css,svelte}'",
		"lint:style:ci": "stylelint --ignore-path .gitignore '**/*.{css,svelte}'",
		"test": "pnpm test:unit",
		"test:unit": "vitest run",
		"test:unit:watch": "vitest",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"check:tiptap-roundtrip": "tsx scripts/tiptap-roundtrip-check.ts",
		"migrate": "tsx scripts/migrate-microcms.ts"
	},
	"devDependencies": {
		"@eslint/compat": "^1.4.1",
		"@eslint/js": "^9.39.1",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-auto": "^6.1.1",
		"@sveltejs/enhanced-img": "^0.9.2",
		"@sveltejs/kit": "^2.53.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/gtag.js": "^0.0.20",
		"@types/node": "^22.19.0",
		"baseline-browser-mapping": "^2.9.15",
		"eslint": "^9.39.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-perfectionist": "^4.15.1",
		"eslint-plugin-svelte": "^3.13.0",
		"eslint-plugin-unicorn": "^61.0.2",
		"globals": "^16.5.0",
		"happy-dom": "^20.9.0",
		"husky": "^9.1.7",
		"jsdom": "^29.0.2",
		"lint-staged": "^16.2.6",
		"msw": "^2.13.4",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"sharp": "^0.34.5",
		"stylelint": "^16.25.0",
		"stylelint-config-html": "^1.1.0",
		"stylelint-config-recess-order": "^7.4.0",
		"stylelint-config-standard": "^39.0.1",
		"svelte": "^5.53.5",
		"svelte-check": "^4.3.3",
		"svelte-meta-tags": "^4.5.0",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.46.3",
		"vite": "^7.2.2",
		"vitest": "^4.0.8"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		],
		"ignoredBuiltDependencies": [
			"msw",
			"sharp"
		]
	},
	"lint-staged": {
		"*.+(js|ts|svelte)": [
			"prettier --write",
			"eslint --fix"
		],
		"*.css": [
			"prettier --write",
			"stylelint --fix"
		],
		"*.+(json|md|html)": "prettier --write",
		"*.svelte": "svelte-check --tsconfig ./tsconfig.json"
	},
	"dependencies": {
		"@sveltejs/adapter-node": "^5.5.4",
		"@tiptap/core": "^3.22.4",
		"@tiptap/extension-bubble-menu": "^3.22.4",
		"@tiptap/extension-color": "^3.22.4",
		"@tiptap/extension-floating-menu": "^3.22.4",
		"@tiptap/extension-image": "^3.22.4",
		"@tiptap/extension-link": "^3.22.4",
		"@tiptap/extension-table": "^3.22.4",
		"@tiptap/extension-text-align": "^3.22.4",
		"@tiptap/extension-text-style": "^3.22.4",
		"@tiptap/extension-underline": "^3.22.4",
		"@tiptap/html": "^3.22.4",
		"@tiptap/starter-kit": "^3.22.4",
		"consola": "^3.4.2",
		"isomorphic-dompurify": "^3.9.0",
		"ky": "^1.14.0",
		"motion": "^12.23.25",
		"pocketbase": "^0.21.5",
		"valibot": "^1.1.0"
	}
}
